# Database
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# AI provider — set at least one. AI_PROVIDER (optional) forces a specific
# adapter; otherwise auto-selects groq > anthropic > gemini.
AI_PROVIDER=""

# Groq (recommended): truly free, no card, ~100k tokens/day on Llama 3.3 70B.
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=""

# Gemini (fallback): free tier 20 RPD per model. Best Arabic quality without
# foreign-token leaks. Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Anthropic (premium): Haiku 4.5 — best Arabic quality. Requires credit
# balance on the API console. Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Auth
BETTER_AUTH_SECRET="generate-a-random-32-char-string"
BETTER_AUTH_URL="http://localhost:3000"

# Google Business Profile (when approved)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="generate-random-string"

# Email
RESEND_API_KEY=""

# Inngest (background jobs)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
